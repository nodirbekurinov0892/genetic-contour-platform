# ─── PostgreSQL ───────────────────────────────────────────────
POSTGRES_USER=genetic_contour
POSTGRES_PASSWORD=genetic_contour_secret
POSTGRES_DB=genetic_contour
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://genetic_contour:genetic_contour_secret@localhost:5432/genetic_contour
REDIS_URL=redis://localhost:6379/0

# ─── Backend (FastAPI) ────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=true
API_PUBLIC_URL=http://localhost:8000
SECRET_KEY=change-me-to-a-random-64-char-string-in-production
JWT_SECRET=change-me-to-another-random-64-char-string-in-production
CORS_ORIGINS=http://localhost:3000,https://your-app.vercel.app
TRUSTED_HOSTS=localhost,127.0.0.1,your-api.onrender.com

# Upload limits
MAX_UPLOAD_SIZE_MB=10
ALLOWED_MIME_TYPES=image/jpeg,image/png,image/webp
UPLOAD_DIR=uploads
RESULTS_DIR=results

# Rate limiting
RATE_LIMIT_PER_MINUTE=60

# GA defaults
GA_DEFAULT_POPULATION_SIZE=50
GA_DEFAULT_GENERATIONS=30
GA_DEFAULT_MUTATION_RATE=0.05
GA_DEFAULT_CROSSOVER_RATE=0.7
GA_DEFAULT_ELITISM_COUNT=2

# ─── Frontend (Next.js) ───────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000

# ─── Production (Render / Vercel) ─────────────────────────────
# DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/dbname
# NEXT_PUBLIC_API_URL=https://your-api.onrender.com
# CORS_ORIGINS=https://your-app.vercel.app
#
# Storage (Render API — choose one backend):
# STORAGE_BACKEND=supabase
# SUPABASE_URL=https://<project>.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=<service_role>
# SUPABASE_STORAGE_BUCKET=genetic-contour-platform
# SUPABASE_PUBLIC_BASE_URL=https://<project>.supabase.co/storage/v1/object/public/genetic-contour-platform
#
# NEXT_PUBLIC_STORAGE_PUBLIC_URL=<same as SUPABASE_PUBLIC_BASE_URL, no trailing slash>
