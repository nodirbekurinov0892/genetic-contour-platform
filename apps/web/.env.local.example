NEXT_PUBLIC_API_URL=http://localhost:8000

# Production (Vercel → Settings → Environment Variables):
# NEXT_PUBLIC_API_URL=https://genetic-contour-platform.onrender.com
# Root Directory must be: apps/web
# Live URL: https://genetic-contour-platform-web.vercel.app
# (genetic-contour.vercel.app is NOT deployed — do not use)

# Required in production when API uses remote object storage (same value as backend public base URL)
# Supabase:
# NEXT_PUBLIC_STORAGE_PUBLIC_URL=https://<project>.supabase.co/storage/v1/object/public/genetic-contour-platform
# S3/R2:
# NEXT_PUBLIC_STORAGE_PUBLIC_URL=https://pub-xxxx.r2.dev
