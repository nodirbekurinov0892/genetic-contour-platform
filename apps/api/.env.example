DATABASE_URL=postgresql+asyncpg://genetic_contour:genetic_contour_secret@localhost:5432/genetic_contour
API_DEBUG=true
API_PUBLIC_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:3000
TRUSTED_HOSTS=localhost,127.0.0.1
SECRET_KEY=dev-secret-change-in-production-use-64-random-chars
JWT_SECRET=dev-jwt-secret-change-in-production-use-64-random-chars

# Queue (Celery + Redis)
REDIS_URL=redis://localhost:6379/0
# CELERY_TASK_ALWAYS_EAGER=true  # optional: run tasks inline without worker (tests)

# Observability (optional)
# SENTRY_DSN=https://xxx@o000.ingest.sentry.io/000
# SENTRY_ENVIRONMENT=development
# LOG_JSON=false

# File storage: local (dev) or s3 (production — AWS S3 / Cloudflare R2)
STORAGE_BACKEND=local

# Required when STORAGE_BACKEND=s3
# S3_ENDPOINT_URL=https://<account_id>.r2.cloudflarestorage.com
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_BUCKET_NAME=genetic-contour
# S3_REGION=auto
# S3_PUBLIC_BASE_URL=https://pub-xxx.r2.dev
